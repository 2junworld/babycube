rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 가족(공유 그룹) 문서: families/{familyId}
    // familyId 자체가 6자리 초대 코드입니다.
    match /families/{familyId} {
      // 로그인한 사용자는 초대 코드로 조회할 수 있어야 하므로 읽기는 로그인 여부만 확인
      allow read: if request.auth != null;

      // 생성: 본인 uid 1명만 members에 넣어서 새로 만드는 경우만 허용
      allow create: if request.auth != null
        && request.resource.data.members is list
        && request.resource.data.members.size() == 1
        && request.auth.uid in request.resource.data.members;

      // 수정: 이미 멤버인 사람의 데이터 수정 OR
      //       초대 코드로 합류하며 본인 uid 1명만 추가되는 경우
      allow update: if request.auth != null
        && (
          request.auth.uid in resource.data.members
          || (
            request.auth.uid in request.resource.data.members
            && request.resource.data.members.size() == resource.data.members.size() + 1
          )
        );
    }

    // 사용자 → 가족 매핑: users/{uid}.familyId
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
